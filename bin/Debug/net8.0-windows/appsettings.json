{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Pos": {
    "IpAddress": "192.168.1.100",
    "Port": "8080",
    "ConnectionType": "TCP"
  },
  "Scale": {
    "PortName": "COM3",
    "BaudRate": "9600",
    "Parity": "None",
    "DataBits": "8",
    "StopBits": "One"
  },
  "Printer": {
    "Name": "",
    "ReceiptFontName": "Tahoma",
    "ReceiptFontSize": "9"
  },
  "Fingerprint": {
    "DeviceType": "ZKTeco",
    "DefaultPort": 4370,
    "TimeoutSeconds": 30
  },
  "Voip": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000"
    ],
    "BridgeToken": "my-local-test-token-123",
    "MaxCallsPerMinute": 30,
    "Provider": "tel_uri"
  }
}
